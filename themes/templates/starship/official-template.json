{
  "name": "starship-theme-template",
  "version": 1,
  "description": "Starship prompt theme template derived from the local Starship prompt configuration contract.",
  "sources": [
    {
      "kind": "official-docs",
      "ref": "Starship configuration reference",
      "url": "https://starship.rs/config/"
    },
    {
      "kind": "official-schema",
      "ref": "Starship TOML schema",
      "url": "https://starship.rs/config-schema.json"
    },
    {
      "kind": "local-example",
      "ref": "existing zsh module Starship config",
      "path": "modules/zsh/starship.toml"
    }
  ],
  "toml_schema": {
    "format_key": "format",
    "palette_table_prefix": "palettes",
    "value_types": ["string", "boolean"]
  },
  "format": "$format",
  "sections": [
    {
      "name": "fill",
      "table": "fill",
      "entries": [
        { "key": "symbol", "value": " " }
      ]
    },
    {
      "name": "directory",
      "table": "directory",
      "entries": [
        { "key": "style", "value": "fg:base bg:foam" },
        { "key": "format", "value": "[ $path ]($style)" },
        { "key": "truncation_length", "value": 4 },
        { "key": "truncation_symbol", "value": "ŌĆ”/" }
      ]
    },
    {
      "name": "directory-substitutions",
      "table": "directory.substitutions",
      "entries": [
        { "key": "Documents", "value": "¾░łÖ " },
        { "key": "Downloads", "value": "¾░ćÜ " },
