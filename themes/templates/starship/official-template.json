  "palette": {
    "name": "$palette_name",
    "entries": [
      { "key": "base", "value": "$base" },
      { "key": "surface", "value": "$surface" },
      { "key": "overlay", "value": "$overlay" },
      { "key": "muted", "value": "$muted" },
      { "key": "subtle", "value": "$subtle" },
      { "key": "text", "value": "$text" },
      { "key": "love", "value": "$love" },
      { "key": "gold", "value": "$gold" },
