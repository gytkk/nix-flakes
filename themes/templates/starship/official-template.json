        { "key": "format", "value": "[[ $symbol $branch ](fg:pine bg:layer3)]($style)" }
      ]
    },
    {
      "name": "git-status",
      "table": "git_status",
      "entries": [
        { "key": "style", "value": "bg:layer3" },
        { "key": "format", "value": "[[($conflicted$staged$modified$untracked$renamed$deleted$stashed$ahead_behind )](fg:pine bg:layer3)]($style)" },
        { "key": "conflicted", "value": "=$count " },
        { "key": "staged", "value": "+$count " },
        { "key": "modified", "value": "!$count " },
        { "key": "untracked", "value": "?$count " },
        { "key": "renamed", "value": "┬╗$count " },
        { "key": "deleted", "value": "-$count " },
        { "key": "stashed", "value": "*$count " },
        { "key": "ahead", "value": "Ōåæ$count" },
        { "key": "behind", "value": "Ōåō$count" },
        { "key": "diverged", "value": "Ōåæ$ahead_countŌåō$behind_count" }
      ]
    },
