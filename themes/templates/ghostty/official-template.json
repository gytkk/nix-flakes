{
  "name": "ghostty-theme-template",
  "version": 1,
  "description": "Ghostty theme template derived from the Ghostty config reference and the existing local terminal config.",
  "sources": [
    {
      "kind": "official-docs",
      "ref": "Ghostty configuration reference",
      "url": "https://ghostty.org/docs/config/reference"
    },
    {
      "kind": "local-example",
      "ref": "existing ghostty module config",
      "path": "modules/ghostty/files/config"
    }
  ],
  "config_schema": {
    "token_prefix": "$",
    "value_type": "hex-or-palette-entry"
  },
  "sections": [
    {
      "name": "ui",
      "entries": [
        { "key": "background", "value": "$background" },
        { "key": "foreground", "value": "$foreground" },
        { "key": "selection-background", "value": "$selection_background" },
        { "key": "selection-foreground", "value": "$selection_foreground" },
        { "key": "cursor-color", "value": "$cursor_color" },
        { "key": "cursor-text", "value": "$cursor_text" }
      ]
    },
    {
      "name": "palette",
      "entries": [
        { "key": "palette", "value": "$palette_0_entry" },
        { "key": "palette", "value": "$palette_1_entry" },
        { "key": "palette", "value": "$palette_2_entry" },
        { "key": "palette", "value": "$palette_3_entry" },
        { "key": "palette", "value": "$palette_4_entry" },
        { "key": "palette", "value": "$palette_5_entry" },
        { "key": "palette", "value": "$palette_6_entry" },
        { "key": "palette", "value": "$palette_7_entry" },
        { "key": "palette", "value": "$palette_8_entry" },
        { "key": "palette", "value": "$palette_9_entry" },
        { "key": "palette", "value": "$palette_10_entry" },
        { "key": "palette", "value": "$palette_11_entry" },
        { "key": "palette", "value": "$palette_12_entry" },
        { "key": "palette", "value": "$palette_13_entry" },
        { "key": "palette", "value": "$palette_14_entry" },
        { "key": "palette", "value": "$palette_15_entry" }
      ]
    }
  ]
}
