{
  "name": "neovim-plugin-highlight-template",
  "version": 1,
  "description": "Plugin-specific Neovim highlight groups kept separate from Neovim official builtin groups.",
  "sources": [
    {
      "kind": "local-config",
      "ref": "nix-flakes plugin highlight support",
      "path": "themes/templates/nvim/plugins.json"
    }
  ],
  "sections": [
    {
      "name": "GitSigns",
      "groups": [
        {
          "group": "GitSignsAdd",
          "attrs": {
            "fg": "$green"
          }
        },
        {
          "group": "GitSignsChange",
          "attrs": {
            "fg": "$yellow"
          }
        },
        {
          "group": "GitSignsDelete",
          "attrs": {
            "fg": "$red"
          }
        }
      ]
    },
    {
      "name": "which-key",
      "groups": [
        {
          "group": "WhichKey",
          "attrs": {
            "fg": "$orange"
          }
        },
        {
          "group": "WhichKeyGroup",
          "attrs": {
            "fg": "$blue"
          }
        },
        {
          "group": "WhichKeyDesc",
          "attrs": {
            "fg": "$fg"
          }
        },
        {
          "group": "WhichKeySeparator",
          "attrs": {
            "fg": "$comment"
          }
        },
        {
          "group": "WhichKeyFloat",
          "attrs": {
            "bg": "$bg_float"
          }
        }
      ]
    },
    {
      "name": "blink.cmp",
      "groups": [
        {
          "group": "BlinkCmpMenu",
          "attrs": {
            "fg": "$fg",
            "bg": "$bg_float"
          }
        },
        {
          "group": "BlinkCmpMenuBorder",
          "attrs": {
            "fg": "$border",
            "bg": "$bg_float"
          }
        },
        {
          "group": "BlinkCmpMenuSelection",
          "attrs": {
            "bg": "$selection"
          }
        },
        {
          "group": "BlinkCmpLabel",
          "attrs": {
            "fg": "$fg"
          }
        },
        {
          "group": "BlinkCmpLabelMatch",
          "attrs": {
            "fg": "$blue",
            "bold": true
          }
        },
        {
          "group": "BlinkCmpKind",
          "attrs": {
            "fg": "$orange"
          }
        },
        {
          "group": "BlinkCmpGhostText",
          "attrs": {
            "fg": "$ghost_text",
            "italic": true
          }
        },
        {
          "group": "MinuetVirtualText",
          "attrs": {
            "link": "BlinkCmpGhostText"
          }
        }
      ]
    },
    {
      "name": "snacks.nvim",
      "groups": [
        {
          "group": "SnacksPickerDir",
          "attrs": {
            "fg": "$comment"
          }
        },
        {
          "group": "SnacksPickerFile",
          "attrs": {
            "fg": "$fg"
          }
        },
        {
          "group": "SnacksPickerMatch",
          "attrs": {
            "fg": "$blue",
            "bold": true
          }
        },
        {
          "group": "SnacksPickerPrompt",
          "attrs": {
            "fg": "$blue"
          }
        },
        {
          "group": "SnacksIndent",
          "attrs": {
            "fg": "$bg_alt"
          }
        },
        {
          "group": "SnacksIndentScope",
          "attrs": {
            "fg": "$selection"
          }
        }
      ]
    },
    {
      "name": "indent-blankline / ibl",
      "groups": [
        {
          "group": "IblIndent",
          "attrs": {
            "fg": "$bg_alt"
          }
        },
        {
          "group": "IblScope",
          "attrs": {
            "fg": "$selection"
          }
        }
      ]
    }
  ]
}
