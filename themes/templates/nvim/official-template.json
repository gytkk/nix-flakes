{
  "name": "neovim-official-highlight-template",
  "version": 1,
  "description": "Official Neovim highlight template derived from builtin help topics, for use as the canonical base when exporting themes.",
  "sources": [
    {
      "kind": "help",
      "ref": "api.txt:*nvim_set_hl()*",
      "path": "runtime/doc/api.txt"
    },
    {
      "kind": "help",
      "ref": "syntax.txt:*highlight-groups*",
      "path": "runtime/doc/syntax.txt"
    },
    {
      "kind": "help",
      "ref": "syntax.txt:*group-name*",
      "path": "runtime/doc/syntax.txt"
    },
    {
      "kind": "help",
      "ref": "treesitter.txt:*treesitter-highlight-groups*",
      "path": "runtime/doc/treesitter.txt"
    },
    {
      "kind": "help",
      "ref": "diagnostic.txt:hl-Diagnostic*",
      "path": "runtime/doc/diagnostic.txt"
    },
    {
      "kind": "help",
      "ref": "lsp.txt:*lsp-semantic-highlight*",
      "path": "runtime/doc/lsp.txt"
    }
  ],
  "highlight_schema": {
    "api": "nvim_set_hl",
    "allowed_keys": [
      "fg",
      "bg",
      "fg_indexed",
      "bg_indexed",
      "sp",
      "blend",
      "bold",
      "standout",
      "underline",
      "undercurl",
      "underdouble",
      "underdotted",
      "underdashed",
      "strikethrough",
      "italic",
      "reverse",
      "nocombine",
      "link",
      "default",
      "ctermfg",
      "ctermbg",
      "cterm"
    ],
    "token_prefix": "$",
    "token_note": "Strings starting with $ reference exporter palette slots. Plain strings are literal values or link targets."
  },
  "sections": [
    {
