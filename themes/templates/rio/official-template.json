{
  "name": "rio-terminal-theme-template",
  "version": 1,
  "description": "Rio Terminal theme template derived from the official Rio configuration color contract.",
  "sources": [
    {
      "kind": "official-docs",
      "ref": "Rio Terminal configuration docs",
      "url": "https://rioterm.com/docs/config"
    },
    {
      "kind": "local-example",
      "ref": "existing rio module theme",
      "path": "modules/rio/themes/one-half-light.toml"
    }
  ],
  "color_schema": {
    "section": "colors",
    "token_prefix": "$",
    "value_type": "hex"
  },
  "sections": [
    {
      "name": "core",
      "entries": [
        { "key": "background", "value": "$background" },
        { "key": "foreground", "value": "$foreground" },
        { "key": "selection-background", "value": "$selection_background" },
        { "key": "selection-foreground", "value": "$selection_foreground" },
        { "key": "tabs", "value": "$tabs" },
        { "key": "tabs-active", "value": "$tabs_active" },
        { "key": "bar", "value": "$bar" },
        { "key": "split", "value": "$split" },
        { "key": "cursor", "value": "$cursor" },
        { "key": "vi-cursor", "value": "$vi_cursor" }
      ]
    },
    {
      "name": "search-and-hints",
      "entries": [
        { "key": "search-match-background", "value": "$search_match_background" },
        { "key": "search-match-foreground", "value": "$search_match_foreground" },
        { "key": "search-focused-match-background", "value": "$search_focused_match_background" },
        { "key": "search-focused-match-foreground", "value": "$search_focused_match_foreground" },
        { "key": "hint-foreground", "value": "$hint_foreground" },
        { "key": "hint-background", "value": "$hint_background" }
      ]
    },
    {
      "name": "ansi",
      "entries": [
        { "key": "black", "value": "$black" },
        { "key": "red", "value": "$red" },
        { "key": "green", "value": "$green" },
        { "key": "yellow", "value": "$yellow" },
        { "key": "blue", "value": "$blue" },
        { "key": "magenta", "value": "$magenta" },
        { "key": "cyan", "value": "$cyan" },
        { "key": "white", "value": "$white" }
      ]
    },
    {
      "name": "dim",
      "entries": [
        { "key": "dim-black", "value": "$dim_black" },
        { "key": "dim-red", "value": "$dim_red" },
        { "key": "dim-green", "value": "$dim_green" },
        { "key": "dim-yellow", "value": "$dim_yellow" },
        { "key": "dim-blue", "value": "$dim_blue" },
        { "key": "dim-magenta", "value": "$dim_magenta" },
        { "key": "dim-cyan", "value": "$dim_cyan" },
        { "key": "dim-white", "value": "$dim_white" },
        { "key": "dim-foreground", "value": "$dim_foreground" }
      ]
    },
    {
      "name": "light",
      "entries": [
        { "key": "light-black", "value": "$light_black" },
        { "key": "light-red", "value": "$light_red" },
        { "key": "light-green", "value": "$light_green" },
        { "key": "light-yellow", "value": "$light_yellow" },
        { "key": "light-blue", "value": "$light_blue" },
        { "key": "light-magenta", "value": "$light_magenta" },
        { "key": "light-cyan", "value": "$light_cyan" },
        { "key": "light-white", "value": "$light_white" },
        { "key": "light-foreground", "value": "$light_foreground" }
      ]
    }
  ]
}
