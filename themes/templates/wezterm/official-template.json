{
  "name": "wezterm-theme-template",
  "version": 1,
  "description": "WezTerm Lua theme template derived from the WezTerm colors and window frame configuration contracts plus the existing local config.",
  "sources": [
    {
      "kind": "official-docs",
      "ref": "Colors & Appearance",
      "url": "https://wezterm.org/config/appearance.html"
    },
    {
      "kind": "official-docs",
      "ref": "window_frame",
      "url": "https://wezterm.org/config/lua/config/window_frame.html"
    },
    {
      "kind": "local-example",
      "ref": "existing wezterm module config",
      "path": "modules/wezterm/files/wezterm.lua"
    }
  ],
  "lua_schema": {
    "root_type": "table",
    "token_prefix": "$",
    "value_types": ["string", "array", "object"]
  },
  "document": {
    "tab_bar": {
      "background": "$tab_bar_background",
      "active_bg": "$active_tab_bg",
      "active_fg": "$active_tab_fg",
      "inactive_bg": "$inactive_tab_bg",
      "inactive_fg": "$inactive_tab_fg",
      "inactive_hover_bg": "$inactive_tab_hover_bg",
      "inactive_hover_fg": "$inactive_tab_hover_fg",
      "edge": "$inactive_tab_edge",
      "new_tab_bg": "$new_tab_bg",
      "new_tab_fg": "$new_tab_fg",
      "new_tab_hover_bg": "$new_tab_hover_bg",
      "new_tab_hover_fg": "$new_tab_hover_fg"
    },
    "window_frame": {
      "active_titlebar_bg": "$window_frame_active_titlebar_bg",
      "inactive_titlebar_bg": "$window_frame_inactive_titlebar_bg",
      "active_titlebar_fg": "$window_frame_active_titlebar_fg",
      "inactive_titlebar_fg": "$window_frame_inactive_titlebar_fg",
      "active_titlebar_border_bottom": "$window_frame_active_titlebar_border_bottom",
      "inactive_titlebar_border_bottom": "$window_frame_inactive_titlebar_border_bottom"
    },
    "colors": {
      "foreground": "$foreground",
      "background": "$background",
      "cursor_bg": "$cursor_bg",
      "cursor_fg": "$cursor_fg",
      "cursor_border": "$cursor_border",
      "selection_fg": "$selection_fg",
      "selection_bg": "$selection_bg",
      "scrollbar_thumb": "$scrollbar_thumb",
      "split": "$split",
      "ansi": [
        "$ansi_0",
        "$ansi_1",
        "$ansi_2",
        "$ansi_3",
        "$ansi_4",
        "$ansi_5",
        "$ansi_6",
        "$ansi_7"
      ],
      "brights": [
        "$bright_0",
        "$bright_1",
        "$bright_2",
        "$bright_3",
        "$bright_4",
        "$bright_5",
        "$bright_6",
        "$bright_7"
      ],
      "tab_bar": {
        "background": "$tab_bar_background",
        "inactive_tab_edge": "$inactive_tab_edge",
        "active_tab": {
          "bg_color": "$active_tab_bg",
          "fg_color": "$active_tab_fg"
        },
        "inactive_tab": {
          "bg_color": "$inactive_tab_bg",
          "fg_color": "$inactive_tab_fg"
        },
        "inactive_tab_hover": {
          "bg_color": "$inactive_tab_hover_bg",
          "fg_color": "$inactive_tab_hover_fg"
        },
        "new_tab": {
          "bg_color": "$new_tab_bg",
          "fg_color": "$new_tab_fg"
        },
        "new_tab_hover": {
          "bg_color": "$new_tab_hover_bg",
          "fg_color": "$new_tab_hover_fg"
        }
      }
    }
  }
}
