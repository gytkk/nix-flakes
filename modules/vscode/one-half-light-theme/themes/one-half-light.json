  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#a0a1a7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": {
        "foreground": "#383a42"
      }
    },
    {
      "scope": ["constant.other.color"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#a626a4"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#a626a4"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#383a42"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html"
      ],
      "settings": {
        "foreground": "#a0a1a7"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["support.function", "support.constant"],
      "settings": {
        "foreground": "#0997b3"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#0184bc"
      }
    },
    {
      "scope": ["meta.class", "entity.name.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["support.type", "support.class", "entity.name.type"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["storage.type.primitive"],
      "settings": {
        "foreground": "#a626a4"
      }
    },
    {
      "scope": ["meta.method.body"],
      "settings": {
        "foreground": "#383a42"
      }
    },
    {
      "scope": [
        "punctuation.definition.variable",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "support.constant"
      ],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["meta.module-reference"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["variable.parameter.function.language.special"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#50a14f"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol",
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#50a14f"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#0997b3"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other.character-class.regexp"
      ],
      "settings": {
        "foreground": "#0997b3"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["punctuation", "punctuation.definition.string"],
      "settings": {
        "foreground": "#50a14f"
      }
    },
    {
      "scope": ["meta.brace", "punctuation.definition.parameters"],
      "settings": {
        "foreground": "#383a42"
      }
    },
    {
      "scope": ["meta.import variable.other.readwrite.alias"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["entity.name.section", "markup.heading"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["markup.underline.link.markdown"],
      "settings": {
        "foreground": "#a626a4"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#a626a4"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#50a14f"
      }
    },
    {
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["meta.separator"],
      "settings": {
        "foreground": "#a0a1a7"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#50a14f"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["source.json meta.structure.dictionary.json support.type.property-name.json"],
      "settings": {
        "foreground": "#e45649"
      }
    },
    {
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#c18401"
      }
    },
    {
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#0184bc"
      }
    },
    {
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#a626a4"
      }
    },
    {
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#50a14f"
      }
    },
    {
      "scope": ["source.yaml entity.name.tag"],
      "settings": {
        "foreground": "#e45649"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.defaultLibrary": "#c18401",
    "function.defaultLibrary": "#0997b3",
    "type.defaultLibrary": "#c18401",
    "class.defaultLibrary": "#c18401",
    "interface.defaultLibrary": "#c18401",
    "enum": "#c18401",
    "enumMember": "#c18401",
    "namespace": "#e45649",
    "function.declaration": "#0184bc",
    "method.declaration": "#0184bc",
    "parameter.declaration": "#383a42",
    "parameter.label": "#e45649",
    "property.declaration": "#e45649",
    "variable.readonly": "#c18401",
    "type": "#c18401",
    "class": "#c18401",
    "interface": "#c18401"
  }
}
