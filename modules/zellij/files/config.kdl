// Managed via Home Manager as the Zellij config.
__PLATFORM_SETTINGS__default_layout "default"
scroll_buffer_size 99000
session_serialization false
show_startup_tips false
theme "__COMMON_THEME__"

keybinds {
    tab {
        bind "h" "j" { GoToPreviousTab; }
        bind "k" "l" { GoToNextTab; }
        bind "Shift h" "Shift j" { MoveTab "Left"; }
        bind "Shift k" "Shift l" { MoveTab "Right"; }
    }

    shared_except "tmux" "locked" {
        unbind "Ctrl b"
    }
}
