#!/usr/bin/env bash

# Terraform version management with lazy loading via nix-direnv
# Versions are loaded on-demand from nixpkgs-terraform, cached in /nix/store

use_terraform() {
  # Watch terraform config files for version changes
  watch_file backend.tf
  watch_file versions.tf
  watch_file main.tf

  # Default version (substituted by Nix)
  local DEFAULT_VERSION="@DEFAULT_VERSION@"
  local AVAILABLE_VERSIONS="@AVAILABLE_VERSIONS@"
  local TERRAFORM_VERSION="$DEFAULT_VERSION"

  # Parse required_version from terraform config files
  for file in "backend.tf" "versions.tf" "main.tf"; do
    if [[ -f "$file" ]]; then
      local VERSION_SPEC
      VERSION_SPEC=$(grep -o 'required_version[ ]*=[ ]*"[^"]*"' "$file" 2>/dev/null | sed 's/.*"\([^"]*\)".*/\1/' | head -1)
      if [[ -n "$VERSION_SPEC" ]]; then
        log_status "Found version spec in $file: $VERSION_SPEC"

        # Parse version from spec
        if [[ "$VERSION_SPEC" =~ ~\>[[:space:]]*([0-9]+\.[0-9]+)([\.0-9]*) ]]; then
          # ~> 1.10 or ~> 1.10.0 style
          local MAJOR_MINOR="${BASH_REMATCH[1]}"
          for version in $AVAILABLE_VERSIONS; do
            if [[ "$version" =~ ^$MAJOR_MINOR\.[0-9]+$ ]]; then
              TERRAFORM_VERSION="$version"
            fi
          done
        elif [[ "$VERSION_SPEC" =~ =[[:space:]]*([0-9]+\.[0-9]+\.[0-9]+) ]]; then
          # = 1.10.5 style
          TERRAFORM_VERSION="${BASH_REMATCH[1]}"
        elif [[ "$VERSION_SPEC" =~ \>=[[:space:]]*([0-9]+\.[0-9]+\.[0-9]+) ]]; then
          # >= 1.10.5 style - use the specified version
          TERRAFORM_VERSION="${BASH_REMATCH[1]}"
        elif [[ "$VERSION_SPEC" =~ ^[[:space:]]*([0-9]+\.[0-9]+\.[0-9]+)[[:space:]]*$ ]]; then
          # Plain version: 1.10.5
          TERRAFORM_VERSION="${BASH_REMATCH[1]}"
        fi
        break
      fi
    fi
  done

  log_status "Using Terraform version: $TERRAFORM_VERSION"

  # If using default version, terraform is already in PATH
  if [[ "$TERRAFORM_VERSION" == "$DEFAULT_VERSION" ]] || [[ "$TERRAFORM_VERSION" == "latest" ]]; then
    log_status "Using default terraform from PATH"
    return 0
  fi

  # Lazy load the requested version via nix-direnv
  # This will fetch/build only on first use, then cache in /nix/store
  local FLAKE_REF="github:stackbuilders/nixpkgs-terraform/67111c56b525073991fcb656ce30e9ad25a78826"

  # Check if nix-direnv's use_flake is available
  if type use_flake &>/dev/null; then
    # Create a temporary flake expression for the specific terraform version
    local FLAKE_DIR="${PWD}/.direnv/terraform-flake"
    mkdir -p "$FLAKE_DIR"

    cat > "$FLAKE_DIR/flake.nix" << EOF
{
  inputs.nixpkgs-terraform.url = "${FLAKE_REF}";
  inputs.nixpkgs-terraform.inputs.nixpkgs.follows = "nixpkgs";
  inputs.nixpkgs.url = "github:nixos/nixpkgs/nixpkgs-unstable";

  outputs = { nixpkgs, nixpkgs-terraform, ... }:
    let
      systems = [ "x86_64-linux" "aarch64-darwin" "aarch64-linux" "x86_64-darwin" ];
      forAllSystems = nixpkgs.lib.genAttrs systems;
    in {
      devShells = forAllSystems (system: {
        default = let
          pkgs = nixpkgs.legacyPackages.\${system};
          terraform = nixpkgs-terraform.packages.\${system}."${TERRAFORM_VERSION}";
        in pkgs.mkShell {
          buildInputs = [ terraform ];
        };
      });
    };
}
EOF

    # Use the flake (nix-direnv will cache this)
    use flake "$FLAKE_DIR"
    log_status "Loaded Terraform $TERRAFORM_VERSION via nix-direnv (cached in /nix/store)"
  else
    # Fallback: use nix-shell directly (slower, but works without nix-direnv)
    log_status "nix-direnv not available, using nix-shell fallback"
    local NIX_EXPR="(builtins.getFlake \"${FLAKE_REF}\").packages.\${builtins.currentSystem}.\"${TERRAFORM_VERSION}\""

    mkdir -p "${PWD}/.direnv/bin"
    cat > "${PWD}/.direnv/bin/terraform" << WRAPPER
#!/usr/bin/env bash
exec nix shell "${FLAKE_REF}#${TERRAFORM_VERSION}" --command terraform "\$@"
WRAPPER
    chmod +x "${PWD}/.direnv/bin/terraform"
    PATH_add "${PWD}/.direnv/bin"
    log_status "Created terraform wrapper for version $TERRAFORM_VERSION"
  fi
}
