#!/usr/bin/env bash

# Terraform version management with lazy loading via nix-direnv
# Versions are loaded on-demand from nixpkgs-terraform, cached in /nix/store

# Compare two dotted versions numerically: prints -1, 0, or 1
_tf_vercmp() {
  local IFS=.
  # shellcheck disable=SC2206
  local a=($1) b=($2)
  local i x y
  for i in 0 1 2; do
    x=${a[i]:-0}
    y=${b[i]:-0}
    if ((x < y)); then
      echo -1
      return
    elif ((x > y)); then
      echo 1
      return
    fi
  done
  echo 0
}

# Regex kept in a variable: macOS bash 3.2 mishandles escaped
# metacharacters written inline in [[ =~ ]]
_TF_CONSTRAINT_RE='^(~>|>=|<=|=|>|<)?[[:space:]]*([0-9]+(\.[0-9]+)*)[[:space:]]*$'

# Check whether every comma-separated constraint in $1 uses a supported operator
_tf_spec_parseable() {
  local constraint
  local IFS=','
  for constraint in $1; do
    constraint="${constraint#"${constraint%%[![:space:]]*}"}"
    [[ "$constraint" =~ $_TF_CONSTRAINT_RE ]] || return 1
  done
  return 0
}

# Check whether version $1 satisfies constraint string $2
# (comma-separated Terraform constraints, e.g. ">= 1.2.0, < 2.0.0")
_tf_satisfies() {
  local ver="$1" spec="$2"
  local constraint op req
  local IFS=','
  for constraint in $spec; do
    constraint="${constraint#"${constraint%%[![:space:]]*}"}"
    if [[ "$constraint" =~ $_TF_CONSTRAINT_RE ]]; then
      op="${BASH_REMATCH[1]:-=}"
      req="${BASH_REMATCH[2]}"
    else
      # Unsupported operator (e.g. !=): treat as unsatisfied so resolution
      # falls back to the default instead of picking a forbidden version
      return 1
    fi
    case "$op" in
      "~>")
        # Pessimistic operator: only the rightmost component may increase
        local parts upper
        IFS=. read -ra parts <<< "$req"
        if ((${#parts[@]} <= 2)); then
          upper="$((parts[0] + 1)).0.0"
        else
          upper="${parts[0]}.$((parts[1] + 1)).0"
        fi
        [[ $(_tf_vercmp "$ver" "$req") -ge 0 && $(_tf_vercmp "$ver" "$upper") -lt 0 ]] || return 1
        ;;
      "=")
        if [[ "$req" == *.*.* ]]; then
          [[ $(_tf_vercmp "$ver" "$req") -eq 0 ]] || return 1
        else
          # Two-component exact spec matches any patch level
          [[ "$ver" == "$req".* ]] || return 1
        fi
        ;;
      ">=") [[ $(_tf_vercmp "$ver" "$req") -ge 0 ]] || return 1 ;;
      "<=") [[ $(_tf_vercmp "$ver" "$req") -le 0 ]] || return 1 ;;
      ">") [[ $(_tf_vercmp "$ver" "$req") -gt 0 ]] || return 1 ;;
      "<") [[ $(_tf_vercmp "$ver" "$req") -lt 0 ]] || return 1 ;;
    esac
  done
  return 0
}

use_terraform() {
  # Watch terraform config files for version changes
  watch_file backend.tf
  watch_file versions.tf
  watch_file main.tf
  watch_file terraform.tf

  # Substituted by Nix (modules/terraform/default.nix)
  local DEFAULT_VERSION="@DEFAULT_VERSION@"
  local AVAILABLE_VERSIONS="@AVAILABLE_VERSIONS@" # ascending order
  local FLAKE_REF="@FLAKE_REF@"
  local NIXPKGS_REF="@NIXPKGS_REF@"
  local TERRAFORM_VERSION="$DEFAULT_VERSION"

  # Find required_version in any .tf file in this directory
  local VERSION_SPEC="" SPEC_FILE="" file spec
  for file in *.tf; do
    [[ -f "$file" ]] || continue
    watch_file "$file"
    spec=$(grep -o 'required_version[[:space:]]*=[[:space:]]*"[^"]*"' "$file" 2> /dev/null | sed 's/.*"\([^"]*\)".*/\1/' | head -1)
    if [[ -n "$spec" ]]; then
      VERSION_SPEC="$spec"
      SPEC_FILE="$file"
      break
    fi
  done

  if [[ -n "$VERSION_SPEC" ]]; then
    log_status "Found version spec in $SPEC_FILE: $VERSION_SPEC"

    if ! _tf_spec_parseable "$VERSION_SPEC"; then
      log_error "use_terraform: unsupported version spec '$VERSION_SPEC', falling back to $DEFAULT_VERSION"
    elif _tf_satisfies "$DEFAULT_VERSION" "$VERSION_SPEC"; then
      TERRAFORM_VERSION="$DEFAULT_VERSION"
    else
      # Pick the highest available version satisfying the constraint
      local candidate=""
      local version
      for version in $AVAILABLE_VERSIONS; do
        if _tf_satisfies "$version" "$VERSION_SPEC"; then
          candidate="$version"
        fi
      done
      if [[ -n "$candidate" ]]; then
        TERRAFORM_VERSION="$candidate"
      else
        log_error "use_terraform: no available terraform version satisfies '$VERSION_SPEC', falling back to $DEFAULT_VERSION"
      fi
    fi
  fi

  log_status "Using Terraform version: $TERRAFORM_VERSION"

  # If using default version, terraform is already in PATH
  if [[ "$TERRAFORM_VERSION" == "$DEFAULT_VERSION" ]] || [[ "$TERRAFORM_VERSION" == "latest" ]]; then
    log_status "Using default terraform from PATH"
    return 0
  fi

  # Lazy load the requested version via nix-direnv
  # This will fetch/build only on first use, then cache in /nix/store

  # Check if nix-direnv's use_flake is available
  if type use_flake &> /dev/null; then
    # Create a temporary flake expression for the specific terraform version
    local FLAKE_DIR="${PWD}/.direnv/terraform-flake"
    mkdir -p "$FLAKE_DIR"

    local FLAKE_CONTENT
    FLAKE_CONTENT=$(cat << EOF
{
  inputs.nixpkgs-terraform.url = "${FLAKE_REF}";
  inputs.nixpkgs-terraform.inputs.nixpkgs.follows = "nixpkgs";
  inputs.nixpkgs.url = "${NIXPKGS_REF}";

  outputs = { nixpkgs, nixpkgs-terraform, ... }:
    let
      systems = [ "x86_64-linux" "aarch64-darwin" "aarch64-linux" "x86_64-darwin" ];
      forAllSystems = nixpkgs.lib.genAttrs systems;
    in {
      devShells = forAllSystems (system: {
        default = let
          pkgs = nixpkgs.legacyPackages.\${system};
          terraform = nixpkgs-terraform.packages.\${system}."terraform-${TERRAFORM_VERSION}";
        in pkgs.mkShell {
          buildInputs = [ terraform ];
        };
      });
    };
}
EOF
    )

    # Only rewrite on change: a fresh mtime on every eval would permanently
    # invalidate nix-direnv's dev-shell cache
    if [[ ! -f "$FLAKE_DIR/flake.nix" ]] || [[ "$FLAKE_CONTENT" != "$(< "$FLAKE_DIR/flake.nix")" ]]; then
      printf '%s\n' "$FLAKE_CONTENT" > "$FLAKE_DIR/flake.nix"
      rm -f "$FLAKE_DIR/flake.lock"
    fi

    # path: prefix keeps Nix from treating the flake as part of an enclosing
    # git repository, where untracked .direnv/ contents are invisible
    unset NIX_DIRENV_DID_FALLBACK
    if use flake "path:$FLAKE_DIR" && [[ -z "${NIX_DIRENV_DID_FALLBACK:-}" ]]; then
      log_status "Loaded Terraform $TERRAFORM_VERSION via nix-direnv (cached in /nix/store)"
    else
      log_error "use_terraform: failed to load Terraform $TERRAFORM_VERSION, terraform in PATH is still $DEFAULT_VERSION"
    fi
  else
    # Fallback: use nix-shell directly (slower, but works without nix-direnv)
    log_status "nix-direnv not available, using nix-shell fallback"

    mkdir -p "${PWD}/.direnv/bin"
    cat > "${PWD}/.direnv/bin/terraform" << WRAPPER
#!/usr/bin/env bash
exec nix shell "${FLAKE_REF}#terraform-${TERRAFORM_VERSION}" --command terraform "\$@"
WRAPPER
    chmod +x "${PWD}/.direnv/bin/terraform"
    PATH_add "${PWD}/.direnv/bin"
    log_status "Created terraform wrapper for version $TERRAFORM_VERSION"
  fi
}
