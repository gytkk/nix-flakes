{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/codex-session-start-sweep",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-agent-status codex running",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/codex-stop-upload",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/plannotator",
            "timeout": 345600
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-agent-status codex done",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
