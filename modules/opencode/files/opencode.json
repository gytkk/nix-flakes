{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "small_model": "openai/gpt-5.3-codex-spark",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "theme": "opencode",
  "autoupdate": true,
  "plugin": [
    "@plannotator/opencode@latest",
    "opencode-anthropic-auth",
    "oh-my-opencode"
  ],
  "tui": {
    "scroll_speed": 3,
    "diff_style": "auto"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "formatter": {
    "nixfmt": {
      "command": ["nixfmt", "$FILE"],
      "extensions": [".nix"]
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    }
  },
  "lsp": {
    "metals": {
      "command": ["metals"],
      "extensions": [".scala", ".sc", ".sbt"]
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf*": "ask"
    },
    "doom_loop": "ask",
    "skill": {
      "*": "allow"
    },
    "task": {
      "*": "allow"
    }
  }
}
