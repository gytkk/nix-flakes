{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "theme": "opencode",
  "autoupdate": true,
  "plugin": ["@plannotator/opencode@latest", "opencode-anthropic-auth", "oh-my-opencode"],
  "tui": {
    "scroll_speed": 3,
    "diff_style": "auto"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "task": {
      "*": "allow"
    }
  },
  "experimental": {
    "hook": {
      "session_completed": [
        {
          "command": ["printf", "\\e]9;OpenCode 응답 완료\\a"]
        }
      ]
    }
  }
}
