{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-5",
  "theme": "opencode",
  "autoupdate": true,
  "plugin": [
    "@plannotator/opencode@latest",
    "file:///Users/gyutak/workspace/opencode-anthropic-auth/index.mjs"
  ],
  "tui": {
    "scroll_speed": 3,
    "diff_style": "auto"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
