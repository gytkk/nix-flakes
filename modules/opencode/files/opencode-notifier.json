{
  "events": {
    "complete": {
      "sound": false,
      "notification": false
    },
    "subagent_complete": {
      "sound": false,
      "notification": false
    }
  },
  "command": {
    "enabled": true,
    "path": "/bin/sh",
    "args": ["-c", "printf '\\033]9;OpenCode: {message}\\007' > /dev/tty 2>/dev/null"],
    "minDuration": 10
  }
}
